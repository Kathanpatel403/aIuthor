# Backend-only environment (copy to backend/.env)
AIUTHOR_ENV=development
AIUTHOR_API_PREFIX=/api

# Memory: "memory" = process-local in-memory store (Phase 2 default). "redis" reserved for later.
AIUTHOR_MEMORY_BACKEND=memory
# Persist memory (facts, concepts, callbacks, …) to <repo>/memory_data/*.json so it survives uvicorn --reload.
AIUTHOR_MEMORY_PERSIST=true
# Optional: custom directory for those JSON files (default: repo root memory_data/)
# AIUTHOR_MEMORY_DATA_DIR=C:/path/to/memory_data

# --- OpenAI (chat agents + embeddings: RAG + tonality fingerprints) ---
OPENAI_API_KEY=
# Optional: custom base (proxy / Azure-style gateway). Default is OpenAI cloud.
# OPENAI_BASE_URL=https://api.openai.com/v1
# Longer timeouts if you see ConnectTimeout / APITimeoutError on slow networks:
OPENAI_HTTP_CONNECT_TIMEOUT_SECONDS=60
OPENAI_HTTP_READ_TIMEOUT_SECONDS=600
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_CHAT_MODEL_MINI=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Token ledger estimates (USD per million tokens — tune to current OpenAI list pricing)
PRICE_OPENAI_PRIMARY_INPUT_PER_MTOK=2.5
PRICE_OPENAI_PRIMARY_OUTPUT_PER_MTOK=10.0
PRICE_OPENAI_MINI_INPUT_PER_MTOK=0.15
PRICE_OPENAI_MINI_OUTPUT_PER_MTOK=0.6

# --- Pinecone (vector index + Inference rerank — same API key, no separate Cohere rerank API) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aiuthor
PINECONE_RERANK_MODEL=cohere-rerank-3.5

# --- Tavily (web RAG) ---
TAVILY_API_KEY=

# Wikipedia for RAG (public MediaWiki API — no key). Two-letter wiki code, e.g. en, de, fr
WIKIPEDIA_LANG=en

# --- RAG tuning (optional) ---
RAG_DENSE_TOP_K=20
RAG_BM25_TOP_K=20
RAG_RRF_K=60
RAG_FINAL_TOP_N=5

# --- Redis (optional future) ---
REDIS_URL=redis://localhost:6379/0

# --- LangSmith ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aiuthor
