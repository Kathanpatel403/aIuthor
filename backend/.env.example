# Backend-only environment (copy to backend/.env)
AIUTHOR_ENV=development
AIUTHOR_API_PREFIX=/api

# Memory: "memory" = process-local in-memory store (Phase 2 default). "redis" reserved for later.
AIUTHOR_MEMORY_BACKEND=memory

# --- Anthropic (Phase 5 — Planner/Writer/Humanizer/Editor/Fact-check; Haiku for Memory keeper) ---
ANTHROPIC_API_KEY=

# --- OpenAI (embeddings: RAG + tonality fingerprints) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Token ledger estimates (USD per million tokens — adjust to match Anthropic pricing)
PRICE_SONNET_INPUT_PER_MTOK=3.0
PRICE_SONNET_OUTPUT_PER_MTOK=15.0
PRICE_HAIKU_INPUT_PER_MTOK=1.0
PRICE_HAIKU_OUTPUT_PER_MTOK=5.0

# --- Pinecone (vector index + Inference rerank — same API key, no separate Cohere rerank API) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aiuthor
PINECONE_RERANK_MODEL=cohere-rerank-3.5

# --- Tavily (web RAG) ---
TAVILY_API_KEY=

# --- RAG tuning (optional) ---
RAG_DENSE_TOP_K=20
RAG_BM25_TOP_K=20
RAG_RRF_K=60
RAG_FINAL_TOP_N=5

# --- Redis (optional future) ---
REDIS_URL=redis://localhost:6379/0

# --- LangSmith ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aiuthor
