# Backend-only environment (copy to backend/.env)
AIUTHOR_ENV=development
AIUTHOR_API_PREFIX=/api

# Memory: "memory" = process-local in-memory store (Phase 2 default). "redis" reserved for later.
AIUTHOR_MEMORY_BACKEND=memory

# --- Anthropic (Phase 5+) ---
ANTHROPIC_API_KEY=

# --- OpenAI (Phase 3+) ---
OPENAI_API_KEY=

# --- Pinecone (Phase 3+) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aiuthor

# --- Cohere (Phase 3+) ---
COHERE_API_KEY=

# --- Tavily (Phase 3+) ---
TAVILY_API_KEY=

# --- Redis (optional; only if AIUTHOR_MEMORY_BACKEND=redis in a future release) ---
REDIS_URL=redis://localhost:6379/0

# --- LangSmith ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aiuthor
